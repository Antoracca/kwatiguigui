# ==============================================================================
# KWATIGUIGUI V2 — Environment Variables
# ==============================================================================
# NEVER commit real values. Copy this file to .env.local and fill in.
# Generate secrets with: openssl rand -base64 32
# ==============================================================================

# --- Next.js ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=KWATIGUIGUI
NODE_ENV=development

# --- Supabase (Public — exposed to browser via NEXT_PUBLIC_ prefix) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Supabase (Private — server-side ONLY, NEVER prefix with NEXT_PUBLIC_) ---
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# The JWT secret is found in: Supabase Dashboard -> Settings -> API -> JWT Secret
# It is used to validate/sign JWTs exchanged with Supabase Auth.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# --- Admin Auth ---
# Separate secret for signing custom admin session JWTs (kwt-admin-session cookie).
# Must be different from SUPABASE_JWT_SECRET.
# Generate with: openssl rand -base64 64
ADMIN_JWT_SECRET=generate-with-openssl-rand-base64-64

# --- Payments: Orange Money RCA ---
ORANGE_MONEY_CLIENT_ID=your-client-id
ORANGE_MONEY_CLIENT_SECRET=your-client-secret
ORANGE_MONEY_MERCHANT_KEY=your-merchant-key
ORANGE_MONEY_API_URL=https://api.orange.com/orange-money-webpay/dev/v1
ORANGE_MONEY_WEBHOOK_SECRET=your-webhook-hmac-secret

# --- Payments: Telecel Money RCA ---
TELECEL_MONEY_API_KEY=your-api-key
TELECEL_MONEY_API_SECRET=your-api-secret
TELECEL_MONEY_MERCHANT_ID=your-merchant-id
TELECEL_MONEY_API_URL=https://api.telecel.cf/v1
TELECEL_MONEY_WEBHOOK_SECRET=your-webhook-hmac-secret

# --- Sentry ---
SENTRY_DSN=https://your-dsn@sentry.io/project-id
SENTRY_AUTH_TOKEN=your-auth-token

# --- Rate Limiting ---
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# --- Admin Setup (one-time only — remove after first admin created via script) ---
# ADMIN_SETUP_EMAIL=admin@kwatiguigui.org
# ADMIN_SETUP_PASSWORD=change-this-immediately
